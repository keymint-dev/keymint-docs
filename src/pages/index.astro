---
import Hero from "../components/Hero.astro";
import DocFeatures from "../components/features/DocFeatures.astro";
import LandingLayout from "../layouts/LandingLayout.astro";
import CodeExample from "../components/CodeExample";

const examples = [
  {
    language: "javascript",
    name: "Node.js",
    code: `const Keymint = require('@keymint/node');

// Initialize the Keymint client
const keymint = new Keymint({
  apiKey: process.env.KEYMINT_API_KEY,
});

// Verify a license key
async function verifyLicense(licenseKey) {
  try {
    const { data, error } = await keymint.licenses.verify(licenseKey);
    
    if (error) {
      console.error('License verification failed:', error);
      return false;
    }
    
    console.log('License is valid:', data);
    return data.valid;
  } catch (err) {
    console.error('Error verifying license:', err);
    return false;
  }
}`,
  },
  {
    language: "python",
    name: "Python",
    code: `from keymint import Keymint
import os

# Initialize the Keymint client
keymint = Keymint(api_key=os.environ["KEYMINT_API_KEY"])

# Verify a license key
def verify_license(license_key):
    try:
        result = keymint.licenses.verify(license_key)
        
        if hasattr(result, 'error'):
            print(f"License verification failed: {result.error}")
            return False
        
        print(f"License is valid: {result.data}")
        return result.data.valid
    except Exception as e:
        print(f"Error verifying license: {e}")
        return False`,
  },
  {
    language: "csharp",
    name: "C#",
    code: `using Keymint;
using System;
using System.Threading.Tasks;

class Program
{
    static async Task Main()
    {
        // Initialize the Keymint client
        var keymint = new KeymintClient(
            apiKey: Environment.GetEnvironmentVariable("KEYMINT_API_KEY")
        );

        // Verify a license key
        await VerifyLicense("LICENSE-KEY-HERE");
    }

    static async Task<bool> VerifyLicense(string licenseKey)
    {
        try
        {
            var result = await keymint.Licenses.Verify(licenseKey);
            
            if (result.Error != null)
            {
                Console.WriteLine($"License verification failed: {result.Error}");
                return false;
            }
            
            Console.WriteLine($"License is valid: {result.Data}");
            return result.Data.Valid;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error verifying license: {ex.Message}");
            return false;
        }
    }
}`,
  },
];
---

<LandingLayout>
  <Hero />

  <DocFeatures />

  <section class="py-16 lg:py-24 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl mb-6">
          Flexible Licensing Models
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-300">
          Keymint supports multiple licensing strategies to fit your software distribution needs.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-slate-50 dark:bg-slate-800 p-6 rounded-lg shadow-sm">
          <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
            Node-Locked Licenses
          </h3>
          <p class="text-slate-600 dark:text-slate-300">
            Tie licenses to specific hardware or machine identifiers. Ideal for preventing unauthorized use and ensuring software is used on authorized devices.
          </p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-800 p-6 rounded-lg shadow-sm">
          <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
            Subscription Licenses
          </h3>
          <p class="text-slate-600 dark:text-slate-300">
            Provide time-based access with automatic renewals. Perfect for SaaS models, ensuring continuous revenue and keeping users updated.
          </p>
        </div>

        <div class="bg-slate-50 dark:bg-slate-800 p-6 rounded-lg shadow-sm">
          <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
            Perpetual Licenses
          </h3>
          <p class="text-slate-600 dark:text-slate-300">
            One-time purchase with optional maintenance. Gives users permanent access to a specific version of your software.
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a 
          href="/docs/licensing-models" 
          class="inline-flex items-center rounded-md bg-brand-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
        >
          Learn More About Licensing
          <svg class="ml-2 -mr-1 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section
    class="py-16 lg:py-24 bg-slate-50 dark:bg-slate-800/25 border-t border-b border-slate-200 dark:border-slate-800"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2
          class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl"
        >
          Ready to get started?
        </h2>
        <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
          Join thousands of software companies that trust Keymint for their
          licensing needs.
        </p>
      </div>

      <div
        class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6"
      >
        <a
          href="/docs/introduction"
          class="w-full sm:w-auto rounded-md bg-brand-600 px-5 py-3 text-center text-base font-medium text-white shadow-sm hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 transition-colors"
        >
          Get Started
        </a>
        <a
          href="https://app.keymint.dev"
          class="w-full sm:w-auto rounded-md border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800 px-5 py-3 text-center text-base font-medium text-slate-700 dark:text-slate-200 shadow-sm hover:bg-slate-50 dark:hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 transition-colors"
        >
          Sign Up Free
        </a>
      </div>
    </div>
  </section>
</LandingLayout>
