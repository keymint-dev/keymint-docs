---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "Official documentation for Keymint - The modern licensing solution for software businesses",
  currentPage,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="https://keymint.dev/favicon.svg"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Theme script to avoid FOUC -->
    <script is:inline>
      const theme = localStorage.getItem("theme") || "light";
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>

    <!-- Custom styles for enhanced markdown -->
    <style>
      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }

      ::-webkit-scrollbar-track {
        background: transparent;
      }

      ::-webkit-scrollbar-thumb {
        background: rgba(148, 163, 184, 0.3);
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: rgba(148, 163, 184, 0.5);
      }

      .dark ::-webkit-scrollbar-thumb {
        background: rgba(71, 85, 105, 0.3);
      }

      .dark ::-webkit-scrollbar-thumb:hover {
        background: rgba(71, 85, 105, 0.5);
      }

      /* Enhanced prose styles */
      .prose-enhanced {
        line-height: 1.75;
        letter-spacing: -0.01em;
      }

      .prose-enhanced h1 {
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 700;
        letter-spacing: -0.025em;
      }

      .prose-enhanced h2 {
        position: relative;
        margin-top: 3rem;
        margin-bottom: 1.5rem;
      }

      .prose-enhanced h2::before {
        content: "";
        position: absolute;
        left: -1.5rem;
        top: 0.5rem;
        width: 4px;
        height: 1.5rem;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        border-radius: 2px;
      }

      .prose-enhanced blockquote {
        border-left: 4px solid #3b82f6;
        background: linear-gradient(
          135deg,
          rgba(59, 130, 246, 0.05),
          rgba(29, 78, 216, 0.05)
        );
        border-radius: 0 8px 8px 0;
        padding: 1.5rem;
        margin: 2rem 0;
        position: relative;
        overflow: hidden;
      }

      .prose-enhanced blockquote::before {
        content: '"';
        position: absolute;
        top: -0.5rem;
        left: 1rem;
        font-size: 3rem;
        color: #3b82f6;
        opacity: 0.2;
        font-family: serif;
      }

      .prose-enhanced pre {
        background: linear-gradient(135deg, #0f172a, #1e293b) !important;
        border: 1px solid rgba(71, 85, 105, 0.3);
        border-radius: 12px;
        padding: 1.5rem;
        overflow-x: auto;
        position: relative;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      }

      .prose-enhanced pre::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6, #06b6d4);
      }

      .prose-enhanced code:not(pre code) {
        background: rgba(59, 130, 246, 0.1);
        color: #1d4ed8;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-weight: 500;
        font-size: 0.9em;
      }

      .dark .prose-enhanced code:not(pre code) {
        background: rgba(59, 130, 246, 0.2);
        color: #60a5fa;
      }

      .prose-enhanced table {
        border-collapse: separate;
        border-spacing: 0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(148, 163, 184, 0.2);
      }

      .prose-enhanced table th {
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
        font-weight: 600;
        text-align: left;
        padding: 1rem;
        border-bottom: 2px solid #e2e8f0;
      }

      .dark .prose-enhanced table th {
        background: linear-gradient(135deg, #1e293b, #334155);
        border-bottom-color: #475569;
      }

      .prose-enhanced table td {
        padding: 1rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
      }

      .prose-enhanced table tr:hover {
        background: rgba(59, 130, 246, 0.05);
      }

      .dark .prose-enhanced table tr:hover {
        background: rgba(59, 130, 246, 0.1);
      }

      /* Enhanced links */
      .prose-enhanced a {
        position: relative;
        color: #3b82f6;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s ease;
      }

      .prose-enhanced a::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, #3b82f6, #1d4ed8);
        transition: width 0.3s ease;
      }

      .prose-enhanced a:hover::after {
        width: 100%;
      }

      /* Lists */
      .prose-enhanced ul {
        padding-left: 0;
        list-style: none;
      }

      .prose-enhanced ul li {
        position: relative;
        padding-left: 2rem;
        margin-bottom: 0.5rem;
      }

      .prose-enhanced ul li::before {
        content: "→";
        position: absolute;
        left: 0;
        color: #3b82f6;
        font-weight: 600;
      }

      .prose-enhanced ol {
        padding-left: 0;
        counter-reset: item;
      }

      .prose-enhanced ol li {
        position: relative;
        padding-left: 2.5rem;
        margin-bottom: 0.5rem;
        counter-increment: item;
      }

      .prose-enhanced ol li::before {
        content: counter(item);
        position: absolute;
        left: 0;
        top: 0;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: white;
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
      }

      /* Fade-in animation for content */
      .content-fade-in {
        animation: fadeIn 0.6s ease-out;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Reading progress bar */
      .reading-progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 0%;
        height: 3px;
        background: linear-gradient(90deg, #3b82f6, #8b5cf6);
        z-index: 100;
        transition: width 0.1s ease;
      }

      /* Table of Contents */
      .toc {
        background: linear-gradient(
          135deg,
          rgba(59, 130, 246, 0.05),
          rgba(29, 78, 216, 0.05)
        );
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 12px;
        padding: 1.5rem;
        margin: 2rem 0;
        position: sticky;
        top: 2rem;
      }

      .toc h3 {
        margin-top: 0;
        color: #3b82f6;
        font-size: 1.1rem;
        font-weight: 600;
      }

      .toc ul {
        margin: 0;
        padding-left: 1rem;
      }

      .toc li {
        margin-bottom: 0.25rem;
      }

      .toc a {
        color: #64748b;
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.2s ease;
      }

      .toc a:hover {
        color: #3b82f6;
      }

      .dark .toc a {
        color: #94a3b8;
      }

      .dark .toc a:hover {
        color: #60a5fa;
      }
    </style>
  </head>

  <body
    class="bg-gradient-to-br from-white via-slate-50 to-blue-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 text-slate-900 dark:text-white antialiased min-h-screen flex flex-col font-inter"
  >
    <!-- Reading progress bar -->
    <div class="reading-progress"></div>

    <Header />

    <div class="flex flex-1 mx-auto w-full max-w-8xl lg:pl-72 relative">
      <aside
        id="mobile-sidebar"
        class="fixed inset-y-0 left-0 z-40 w-72 bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-950 border-r border-slate-200/80 dark:border-slate-800/80 transform transition-transform duration-300 ease-in-out -translate-x-full lg:translate-x-0 backdrop-blur-sm"
      >
        <Sidebar currentPage={Astro.url.pathname} />
      </aside>

      <main
        class="flex-1 px-6 py-8 md:px-12 lg:px-16 max-w-none overflow-x-hidden"
      >
        <article
          class="prose prose-lg prose-slate dark:prose-invert prose-enhanced max-w-4xl mx-auto content-fade-in"
        >
          <div class="mb-2 pb-1"></div>

          <slot />

          <!-- Next/Previous navigation -->
        </article>
      </main>
    </div>

    <!-- Enhanced Mobile Sidebar Toggle -->
    <button
      id="mobile-sidebar-toggle"
      class="fixed top-4 left-4 z-50 lg:hidden p-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-105"
    >
      <svg
        class="w-5 h-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        // Mobile sidebar functionality
        const sidebarToggle = document.getElementById("mobile-sidebar-toggle");
        const mobileSidebar = document.getElementById("mobile-sidebar");

        if (sidebarToggle && mobileSidebar) {
          sidebarToggle.addEventListener("click", () => {
            mobileSidebar.classList.toggle("-translate-x-full");

            if (mobileSidebar.classList.contains("-translate-x-full")) {
              document.getElementById("mobile-sidebar-backdrop")?.remove();
            } else {
              const backdrop = document.createElement("div");
              backdrop.id = "mobile-sidebar-backdrop";
              backdrop.classList.add(
                "fixed",
                "inset-0",
                "bg-black",
                "bg-opacity-50",
                "z-30",
                "lg:hidden",
                "backdrop-blur-sm"
              );
              backdrop.addEventListener("click", () => {
                mobileSidebar.classList.add("-translate-x-full");
                backdrop.remove();
              });
              document.body.appendChild(backdrop);
            }
          });
        }

        // Reading progress bar
        const progressBar = document.querySelector(".reading-progress");
        if (progressBar) {
          const updateProgress = () => {
            const totalHeight =
              document.documentElement.scrollHeight - window.innerHeight;
            const progress = (window.scrollY / totalHeight) * 100;
            progressBar.style.width = `${Math.min(progress, 100)}%`;
          };

          window.addEventListener("scroll", updateProgress);
          updateProgress();
        }

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
          anchor.addEventListener("click", function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute("href"));
            if (target) {
              target.scrollIntoView({
                behavior: "smooth",
                block: "start",
              });
            }
          });
        });
      });
    </script>
  </body>
</html>
