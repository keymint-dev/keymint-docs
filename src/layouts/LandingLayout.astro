---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";

export interface Props {
  title?: string;
  description?: string;
  showSidebar?: boolean;
}

const {
  title = "Keymint Documentation",
  description = "Official documentation for Keymint - The modern licensing solution for software businesses",
  showSidebar = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="https://keymint.dev/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Theme script to avoid FOUC -->
    <script is:inline>
      const theme = localStorage.getItem("theme") || "light";
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>
  <body
    class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white antialiased min-h-screen flex flex-col"
  >
    <div class="flex">
      {showSidebar && <Sidebar currentPage={Astro.url.pathname} />}
      <main class="flex-1">
        <slot />
      </main>
    </div>
  </body>
</html>
