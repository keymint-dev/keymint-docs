---
import ThemeToggle from "./ThemeToggle.astro";
import { navigation } from "./NavLinks.astro";
import MobileNav from "./MobileNav.astro";
---

<header
  class="fixed top-0 z-50 w-full backdrop-blur-xl border-b border-slate-200/20 dark:border-slate-700/30 bg-white/95 dark:bg-slate-900/95 transition-all duration-300 shadow-sm dark:shadow-slate-900/20"
>
  <div class="mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 sm:h-18 items-center justify-between">
      <!-- Logo Section -->
      <div class="hidden sm:flex items-center">
        <a
          href="/"
          class="block group transition-transform duration-200 hover:scale-105"
          aria-label="Keymint Home"
        >
          <div class="relative">
            <img
              src="https://keymint.dev/logo.png"
              alt="Keymint Logo"
              class="w-12 h-12 sm:w-16 sm:h-16 md:w-20 md:h-20 lg:w-24 lg:h-24 rounded-md object-contain"
            />
          </div>
        </a>

        <!-- Brand name (optional, uncomment if needed) -->
        <!-- <span class="ml-3 text-xl font-bold text-slate-900 dark:text-white hidden sm:block">
          Keymint
        </span> -->
      </div>

      <!-- Navigation Actions -->
      <div class="flex items-center space-x-3 sm:space-x-4">
        <!-- Theme Toggle with enhanced styling -->
        <div class="flex items-center">
          <ThemeToggle />
        </div>

        <!-- Dashboard Button - Enhanced -->
        <a
          href="https://app.keymint.dev"
          class="hidden sm:flex items-center space-x-2 text-sm font-semibold bg-slate-800 hover:bg-slate-700 text-white px-5 py-2.5 rounded-xl transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 active:translate-y-0"
        >
          <span>Dashboard</span>
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>

        <!-- Enhanced Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="lg:hidden relative inline-flex items-center justify-center p-2.5 rounded-xl text-slate-600 hover:text-slate-900 hover:bg-slate-50 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-slate-800/50 transition-all duration-200 border border-transparent hover:border-slate-200 dark:hover:border-slate-700"
          aria-label="Toggle mobile menu"
        >
          <!-- Hamburger Icon -->
          <svg
            class="h-5 w-5 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            id="menu-icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>

          <!-- Close Icon (hidden by default) -->
          <svg
            class="h-5 w-5 absolute inset-0 m-auto transition-transform duration-200 rotate-90 opacity-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            id="close-icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

</header>

<style>
  /* Custom brand colors - adjust these to match your brand */
  :root {
    --brand-50: #eff6ff;
    --brand-100: #dbeafe;
    --brand-200: #bfdbfe;
    --brand-300: #93c5fd;
    --brand-400: #60a5fa;
    --brand-500: #3b82f6;
    --brand-600: #2563eb;
    --brand-700: #1d4ed8;
    --brand-800: #1e40af;
    --brand-900: #1e3a8a;
  }
</style>
