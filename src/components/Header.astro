---
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="sticky top-0 z-50 w-full backdrop-blur-xl border-b border-slate-200/20 dark:border-slate-700/30 bg-white/95 dark:bg-slate-900/95 transition-all duration-300 shadow-sm dark:shadow-slate-900/20"
>
  <div class="mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 sm:h-18 items-center justify-between">
      <!-- Logo Section -->
      <div class="flex items-center">
        <a
          href="/"
          class="block group transition-transform duration-200 hover:scale-105"
          aria-label="Keymint Home"
        >
          <div class="relative">
            <img
              src="https://keymint.dev/logo.png"
              alt="Keymint Logo"
              class="w-12 h-12 sm:w-16 sm:h-16 md:w-20 md:h-20 lg:w-24 lg:h-24 rounded-md object-contain"
            />
            <!-- Subtle glow effect on hover -->
            <div
              class="absolute inset-0 rounded-xl bg-gradient-to-r from-brand-500/20 to-brand-600/20 opacity-0 group-hover:opacity-100 transition-opacity duration-200 -z-10 blur-sm"
            >
            </div>
          </div>
        </a>

        <!-- Brand name (optional, uncomment if needed) -->
        <!-- <span class="ml-3 text-xl font-bold text-slate-900 dark:text-white hidden sm:block">
          Keymint
        </span> -->
      </div>

      <!-- Navigation Actions -->
      <div class="flex items-center space-x-3 sm:space-x-4">
        <!-- Theme Toggle with enhanced styling -->
        <div class="flex items-center">
          <ThemeToggle />
        </div>

        <!-- Dashboard Button - Enhanced -->
        <a
          href="https://app.keymint.dev"
          class="hidden sm:flex items-center space-x-2 text-sm font-semibold bg-gradient-to-r from-brand-600 to-brand-700 hover:from-brand-700 hover:to-brand-800 text-white px-5 py-2.5 rounded-xl transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 active:translate-y-0"
        >
          <span>Dashboard</span>
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>

        <!-- Enhanced Mobile Menu Button -->
        <button
          id="mobile-menu-button"
          class="md:hidden relative inline-flex items-center justify-center p-2.5 rounded-xl text-slate-600 hover:text-brand-600 hover:bg-slate-50 dark:text-slate-400 dark:hover:text-brand-400 dark:hover:bg-slate-800/50 transition-all duration-200 border border-transparent hover:border-slate-200 dark:hover:border-slate-700"
          aria-label="Toggle mobile menu"
        >
          <!-- Hamburger Icon -->
          <svg
            class="h-5 w-5 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            id="menu-icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>

          <!-- Close Icon (hidden by default) -->
          <svg
            class="h-5 w-5 absolute inset-0 m-auto transition-transform duration-200 rotate-90 opacity-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            id="close-icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Enhanced Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl border-b border-slate-200/20 dark:border-slate-700/30 shadow-lg"
  >
    <div class="px-4 pt-4 pb-6 space-y-3">
      <!-- Mobile Dashboard Button -->
      <a
        href="https://app.keymint.dev"
        class="flex items-center justify-center space-x-2 w-full px-4 py-3 text-base font-semibold rounded-xl bg-gradient-to-r from-brand-600 to-brand-700 hover:from-brand-700 hover:to-brand-800 text-white transition-all duration-200 shadow-sm hover:shadow-md"
      >
        <span>Go to Dashboard</span>
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>

      <!-- Additional mobile menu items can go here -->
      <!-- Example:
      <a
        href="/features"
        class="block px-4 py-3 text-base font-medium text-slate-700 dark:text-slate-300 hover:text-brand-600 dark:hover:text-brand-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 rounded-xl transition-colors duration-200"
      >
        Features
      </a>
      -->
    </div>
  </div>
</header>

<script>
  // Enhanced mobile menu toggle with icon animation
  document.addEventListener("DOMContentLoaded", function () {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIcon = document.getElementById("menu-icon");
    const closeIcon = document.getElementById("close-icon");

    if (mobileMenuButton && mobileMenu && menuIcon && closeIcon) {
      mobileMenuButton.addEventListener("click", function () {
        const isHidden = mobileMenu.classList.contains("hidden");

        if (isHidden) {
          // Show menu
          mobileMenu.classList.remove("hidden");
          menuIcon.style.opacity = "0";
          menuIcon.style.transform = "rotate(-90deg)";
          closeIcon.style.opacity = "1";
          closeIcon.style.transform = "rotate(0deg)";
        } else {
          // Hide menu
          mobileMenu.classList.add("hidden");
          menuIcon.style.opacity = "1";
          menuIcon.style.transform = "rotate(0deg)";
          closeIcon.style.opacity = "0";
          closeIcon.style.transform = "rotate(90deg)";
        }
      });
    }
  });
</script>

<style>
  /* Custom brand colors - adjust these to match your brand */
  :root {
    --brand-50: #eff6ff;
    --brand-100: #dbeafe;
    --brand-200: #bfdbfe;
    --brand-300: #93c5fd;
    --brand-400: #60a5fa;
    --brand-500: #3b82f6;
    --brand-600: #2563eb;
    --brand-700: #1d4ed8;
    --brand-800: #1e40af;
    --brand-900: #1e3a8a;
  }

  .bg-brand-600 {
    background-color: var(--brand-600);
  }

  .bg-brand-700 {
    background-color: var(--brand-700);
  }

  .bg-brand-800 {
    background-color: var(--brand-800);
  }

  .hover\:bg-brand-700:hover {
    background-color: var(--brand-700);
  }

  .hover\:bg-brand-800:hover {
    background-color: var(--brand-800);
  }

  .text-brand-600 {
    color: var(--brand-600);
  }

  .text-brand-400 {
    color: var(--brand-400);
  }

  .hover\:text-brand-600:hover {
    color: var(--brand-600);
  }

  .hover\:text-brand-400:hover {
    color: var(--brand-400);
  }

  .from-brand-500\/20 {
    --tw-gradient-from: rgb(59 130 246 / 0.2);
  }

  .to-brand-600\/20 {
    --tw-gradient-to: rgb(37 99 235 / 0.2);
  }

  .from-brand-600 {
    --tw-gradient-from: var(--brand-600);
  }

  .from-brand-700 {
    --tw-gradient-from: var(--brand-700);
  }

  .to-brand-700 {
    --tw-gradient-to: var(--brand-700);
  }

  .to-brand-800 {
    --tw-gradient-to: var(--brand-800);
  }

  .hover\:from-brand-700:hover {
    --tw-gradient-from: var(--brand-700);
  }

  .hover\:from-brand-800:hover {
    --tw-gradient-from: var(--brand-800);
  }

  .hover\:to-brand-800:hover {
    --tw-gradient-to: var(--brand-800);
  }
</style>
