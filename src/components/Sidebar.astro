---
import { navigation } from "./NavLinks.astro";
import type { Link, NavigationItem } from "../types";

const { currentPage } = Astro.props;

function isCurrentPage(href: string): boolean {
  return currentPage === href;
}

function isActiveSection(section: NavigationItem): boolean {
  if (!section?.links) return false;
  return section.links.some(
    (link) => {
      if (!link) return false;
      return isCurrentPage(link.href) || isSubSectionActive(link, currentPage);
    }
  );
}

function isSubSectionActive(link: Link, currentPage: string): boolean {
  if (!link?.links) return false;
  return link.links.some((sublink) => sublink ? isCurrentPage(sublink.href) : false);
}
---

<nav
  class="fixed top-0 left-0 h-screen w-72 overflow-y-auto pt-24 pb-8 px-6 bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-950 border-r border-slate-200/80 dark:border-slate-800/80 z-40 backdrop-blur-sm"
>
  <ul class="space-y-6">
    {
      navigation.map((section, index) => {
        const isActive = isActiveSection(section);
        return (
          <li class="sidebar-section">
            <div class={`relative mb-3 ${isActive ? "border-l-2 border-blue-500 pl-3" : ""}`}>
              <div class="uppercase tracking-wider font-bold text-[10px] text-slate-500 dark:text-slate-400 mb-3 px-2">
                <span class="flex items-center gap-2">{section.title}</span>
              </div>
            </div>

            <ul class="space-y-1 section-links">
              {section.links.map((link, linkIndex) => {
                if (!link) return null;
                const hasSubLinks = link.links && link.links.length > 0;
                const subSectionInitiallyExpanded = isSubSectionActive(link, currentPage);

                return (
                  <li class="sub-section-container">
                    {hasSubLinks ? (
                      <div class="group">
                        <div class="flex items-center justify-between rounded-lg hover:bg-slate-100/70 dark:hover:bg-slate-800/50 transition-all duration-200">
                          <a
                            href={link.href}
                            class:list={[
                              "flex-grow block px-4 py-2.5 text-sm font-medium transition-all duration-200 rounded-l-lg",
                              isCurrentPage(link.href)
                                ? "bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-lg shadow-blue-500/25"
                                : "text-slate-700 dark:text-slate-300 hover:text-blue-600 dark:hover:text-blue-400",
                            ]}
                          >
                            <span class="flex items-center gap-2">
                              {link.title}
                              {hasSubLinks && link.links && (
                                <span class="text-xs bg-slate-200 dark:bg-slate-700 px-1.5 py-0.5 rounded-full">
                                  {link.links.length}
                                </span>
                              )}
                            </span>
                          </a>
                          <button
                            type="button"
                            class="p-2.5 rounded-r-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1 focus-visible:ring-blue-500 dark:focus-visible:ring-offset-slate-900 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all duration-200"
                            aria-expanded={subSectionInitiallyExpanded.toString()}
                            aria-controls={`sidebar-links-${index}-sub-${linkIndex}`}
                            data-subsection-toggle
                          >
                            <svg
                              class:list={[
                                "w-4 h-4 transform transition-transform duration-200 chevron-icon",
                                { "rotate-90": subSectionInitiallyExpanded },
                              ]}
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                            >
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                            <span class="sr-only">Toggle {link.title} sub-menu</span>
                          </button>
                        </div>
                      </div>
                    ) : (
                      <a
                        href={link.href}
                        class:list={[
                          "block px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 hover:scale-[1.02]",
                          isCurrentPage(link.href)
                            ? "bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-lg shadow-blue-500/25 transform"
                            : "text-slate-700 dark:text-slate-300 hover:bg-slate-100/70 dark:hover:bg-slate-800/50 hover:text-blue-600 dark:hover:text-blue-400",
                        ]}
                      >
                        {link.title}
                      </a>
                    )}

                    {hasSubLinks && (
                      <ul
                        id={`sidebar-links-${index}-sub-${linkIndex}`}
                        class:list={[
                          "ml-6 mt-2 space-y-1 border-l-2 border-slate-200 dark:border-slate-700 pl-4 sub-section-links transition-all duration-300",
                          !subSectionInitiallyExpanded ? "hidden opacity-0" : "opacity-100",
                        ]}
                      >
                        {link.links?.map((sublink) => {
                          if (!sublink) return null;
                          return (
                            <li>
                              <a
                                href={sublink.href}
                                class:list={[
                                  "block py-2 px-3 text-sm rounded-md transition-all duration-200 hover:translate-x-1",
                                  isCurrentPage(sublink.href)
                                    ? "text-blue-600 dark:text-blue-400 font-semibold bg-blue-50 dark:bg-blue-950/50 border-l-2 border-blue-500 pl-2"
                                    : "text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-50 dark:hover:bg-slate-800/30",
                                ]}
                              >
                                <span class="flex items-center gap-2">
                                  <span class="w-1.5 h-1.5 rounded-full bg-current opacity-50" />
                                  {sublink.title}
                                </span>
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    )}
                  </li>
                );
              })}
            </ul>
          </li>
        );
      })
    }
  </ul>
</nav>

<script>
  function initializeSidebarCollapsibles() {
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-subsection-toggle]");
    buttons.forEach((button) => {
      const controlledLinksId = button.getAttribute("aria-controls");
      if (!controlledLinksId) return;

      const links = document.getElementById(controlledLinksId);
      const icon = button.querySelector<HTMLElement>(".chevron-icon");
      if (!links || !icon) return;

      if (button.dataset.listenerAttached === "true") return;

      button.addEventListener("click", () => {
        const isHidden = links.classList.contains("hidden");
        if (isHidden) {
          links.classList.remove("hidden", "opacity-0");
          button.setAttribute("aria-expanded", "true");
          icon.classList.add("rotate-90");
        } else {
          links.classList.add("opacity-0");
          setTimeout(() => {
            links.classList.add("hidden");
          }, 200);
          button.setAttribute("aria-expanded", "false");
          icon.classList.remove("rotate-90");
        }
      });
      button.dataset.listenerAttached = "true";
    });
  }

  document.addEventListener("astro:page-load", initializeSidebarCollapsibles);
</script>
